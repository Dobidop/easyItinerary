# POI Extraction Server — configuration
# Copy to .env or set these as environment variables before running poi-server.js

# AI provider: 'openai', 'anthropic', or 'poorclaudeapi'
POI_PROVIDER=openai

# Your API key (not required for poorclaudeapi)
POI_API_KEY=sk-...

# Model to use (optional — defaults shown below)
#   openai:        gpt-4o-mini
#   anthropic:     claude-haiku-4-5-20251001
#   poorclaudeapi: sonnet
# POI_MODEL=gpt-4o-mini

# Base URL (optional — only needed for non-default providers)
# openai default:        https://api.openai.com
# anthropic:             https://api.anthropic.com  (set automatically)
# poorclaudeapi:         http://127.0.0.1:8000       (set automatically)
# LM Studio:             http://localhost:1234
# Groq:                  https://api.groq.com/openai
# OpenRouter:            https://openrouter.ai/api
# POI_BASE_URL=http://localhost:1234

# Port (optional, default: 3004)
# POI_PORT=3004
